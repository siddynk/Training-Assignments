public class GCDemo {
    public void finalize() {
        System.out.println("Object is being cleared by Garbage Collector!");
    }
    public static void main(String[] args) {
        GCDemo obj1 = new GCDemo();
        obj1 = null;
        System.gc(); 
        System.out.println("Garbage Collection requested.");
    }
}
