public class methodover {
    static void add(int a, int b) {
        System.out.println("Sum of two: " + (a + b));
    }
    static void add(int a, int b, int c) {
        System.out.println("Sum of three: " + (a + b + c));
    }
    public static void main(String[] args) {
        add(5, 10);
        add(5, 10, 15);
    }
}


