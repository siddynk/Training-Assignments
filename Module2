public class fact{
    // This is the recursive method
    public static int calc(int n) {
        if (n <= 1) {
            return 1;
        } else {
            return n * calc(n - 1);
        }
    }

    public static void main(String[] args) {
        int num = 5;
        int result = calc(num);
        System.out.println("Factorial of " + num + " is: " + result);
    }
}