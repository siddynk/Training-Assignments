package dsa.collections_searching_sorting;

public class Occurrences {
    public static int find(int[] arr, int target, boolean first) {
        int low = 0, high = arr.length - 1, res = -1;
        while (low <= high) {
            int mid = low + (high - low) / 2;
            if (arr[mid] == target) {
                res = mid;
                if (first) high = mid - 1; else low = mid + 1;
            } else if (arr[mid] < target) low = mid + 1;
            else high = mid - 1;
        }
        return res;
    }
}

